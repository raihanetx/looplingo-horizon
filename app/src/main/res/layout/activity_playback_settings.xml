<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Playback Settings"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start Action"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/rg_start_action"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rb_autoplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Autoplay Immediately"
                android:textColor="@color/white" />

            <RadioButton
                android:id="@+id/rb_wait"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Load and Wait"
                android:textColor="@color/white" />

        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loop Mode"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinner_loop_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/teal_200" />

        <LinearLayout
            android:id="@+id/layout_loop_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loop Count:"
                android:textColor="@color/white"
                android:layout_gravity="center_vertical" />

            <EditText
                android:id="@+id/et_loop_count"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="10"
                android:textColor="@color/white"
                android:inputType="number"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Playback Range (seconds)"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/et_range_start"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0"
                android:textColor="@color/white"
                android:hint="Start"
                android:textColorHint="@color/teal_200"
                android:inputType="number" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" to "
                android:textColor="@color/white"
                android:layout_gravity="center_vertical"
                android:layout_marginHorizontal="8dp" />

            <EditText
                android:id="@+id/et_range_end"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textColor="@color/white"
                android:hint="End (empty=entire)"
                android:textColorHint="@color/teal_200"
                android:inputType="number" />

        </LinearLayout>

        <CheckBox
            android:id="@+id/cb_auto_advance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Auto-Advance after loop completes"
            android:textColor="@color/white"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btn_apply"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Apply Settings"
            android:backgroundTint="@color/purple_500" />

    </LinearLayout>

</ScrollView>
