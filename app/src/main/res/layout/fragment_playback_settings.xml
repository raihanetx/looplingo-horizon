<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorSurface"
        app:elevation="@dimen/app_bar_elevation">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationContentDescription="@string/content_desc_navigate_up"
            app:title="@string/playback_settings"
            app:titleTextAppearance="@style/TextAppearance.Horizon.TitleLarge"
            app:titleTextColor="@color/colorOnSurface" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingVertical="@dimen/space_lg">

            <!-- ════════ Now Playing + Transport Controls ════════ -->
            <TextView
                style="@style/Widget.Horizon.SectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_transport_controls" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_now_playing"
                style="@style/Widget.Horizon.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg"
                app:cardBackgroundColor="@color/colorPrimaryContainer">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">

                    <!-- Row 1: Title + Position -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_audio_track"
                            app:tint="@color/colorOnPrimaryContainer" />

                        <TextView
                            android:id="@+id/tv_now_playing_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/space_sm"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textAppearance="@style/TextAppearance.Horizon.BodyMedium"
                            android:textColor="@color/colorOnPrimaryContainer" />

                        <TextView
                            android:id="@+id/tv_now_playing_position"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_sm"
                            android:textAppearance="@style/TextAppearance.Horizon.LabelSmall"
                            android:textColor="@color/colorOnPrimaryContainer" />

                    </LinearLayout>

                    <!-- Row 2: Transport controls (rewind 5s, play/pause, stop, forward 5s) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/iv_rewind_5"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/content_desc_rewind_5"
                            android:scaleType="centerInside"
                            app:srcCompat="@drawable/ic_rewind_5"
                            app:tint="@color/colorOnPrimaryContainer" />

                        <ImageView
                            android:id="@+id/iv_play_pause"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_marginHorizontal="@dimen/space_md"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/content_desc_play_pause"
                            android:scaleType="centerInside"
                            app:srcCompat="@drawable/ic_play"
                            app:tint="@color/colorOnPrimaryContainer" />

                        <ImageView
                            android:id="@+id/iv_stop"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/content_desc_stop"
                            android:scaleType="centerInside"
                            app:srcCompat="@drawable/ic_stop"
                            app:tint="@color/colorOnPrimaryContainer" />

                        <ImageView
                            android:id="@+id/iv_forward_5"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="@dimen/space_md"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/content_desc_forward_5"
                            android:scaleType="centerInside"
                            app:srcCompat="@drawable/ic_forward_5"
                            app:tint="@color/colorOnPrimaryContainer" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ════════ Subtitle Overlay ════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_subtitle_overlay"
                style="@style/Widget.Horizon.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg"
                android:visibility="gone"
                app:cardBackgroundColor="@color/colorSurfaceContainerHighest">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">

                    <TextView
                        style="@style/Widget.Horizon.SectionHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/section_live_subtitle" />

                    <TextView
                        android:id="@+id/tv_subtitle_original"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.Horizon.BodyLarge"
                        android:textColor="@color/colorOnSurface"
                        android:textStyle="bold"
                        android:minHeight="28dp"
                        android:gravity="center_vertical" />

                    <TextView
                        android:id="@+id/tv_subtitle_translation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:textAppearance="@style/TextAppearance.Horizon.BodyMedium"
                        android:textColor="@color/colorPrimary"
                        android:minHeight="24dp"
                        android:gravity="center_vertical" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ════════ A-B Loop Range ════════ -->
            <TextView
                style="@style/Widget.Horizon.SectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_loop_range" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Horizon.CardView.Filled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_range_start"
                            style="@style/Widget.Horizon.TextInputLayout.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/hint_start_time"
                            app:errorEnabled="true">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_range_start"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:text="0:00"
                                android:textAppearance="@style/TextAppearance.Horizon.BodyLarge" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_marginHorizontal="@dimen/space_sm"
                            android:text="@string/range_separator"
                            android:textAppearance="@style/TextAppearance.Horizon.BodyLarge"
                            android:textColor="@color/colorOnSurfaceVariant" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_range_end"
                            style="@style/Widget.Horizon.TextInputLayout.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/hint_end_time"
                            app:errorEnabled="true">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_range_end"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:text=""
                                android:textAppearance="@style/TextAppearance.Horizon.BodyLarge" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:text="@string/hint_time_format"
                        android:textAppearance="@style/TextAppearance.Horizon.BodySmall"
                        android:textColor="@color/colorOnSurfaceVariant" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_loop_count"
                        style="@style/Widget.Horizon.TextInputLayout.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:hint="@string/loop_count_label"
                        app:errorEnabled="true">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_loop_count"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLength="5"
                            android:text="5"
                            android:textAppearance="@style/TextAppearance.Horizon.BodyLarge" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Try loop button — preview before saving -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_try_loop"
                        style="@style/Widget.Horizon.Button.Tonal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/btn_try_loop"
                        app:icon="@drawable/ic_play"
                        app:iconGravity="textStart" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ════════ Speed Control (instant apply) ════════ -->
            <TextView
                style="@style/Widget.Horizon.SectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_speed" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Horizon.CardView.Filled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chip_group_speed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:singleSelection="true"
                            app:chipSpacingHorizontal="@dimen/space_sm" />

                    </HorizontalScrollView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:text="@string/speed_instant_hint"
                        android:textAppearance="@style/TextAppearance.Horizon.BodySmall"
                        android:textColor="@color/colorOnSurfaceVariant" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ════════ Saved Timestamps ════════ -->
            <LinearLayout
                android:id="@+id/layout_saved_timestamps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/Widget.Horizon.SectionHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/section_saved_timestamps" />

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Horizon.CardView.Filled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_lg">

                    <LinearLayout
                        android:id="@+id/saved_timestamps_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_md" />

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ════════ AI Subtitles ════════ -->
            <TextView
                style="@style/Widget.Horizon.SectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_ai_subtitles" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Horizon.CardView.Filled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">

                    <!-- API Key banner — prominent warning when no key is set -->
                    <TextView
                        android:id="@+id/tv_api_key_banner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/api_key_required_banner"
                        android:textAppearance="@style/TextAppearance.Horizon.BodyMedium"
                        android:textColor="@color/colorOnErrorContainer"
                        android:background="@color/colorErrorContainer"
                        android:paddingHorizontal="@dimen/space_md"
                        android:paddingVertical="@dimen/space_md"
                        android:layout_marginBottom="@dimen/space_md"
                        android:visibility="gone" />

                    <!-- Groq API Key input — always visible and prominent -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_groq_api_key"
                        style="@style/Widget.Horizon.TextInputLayout.Filled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_groq_api_key"
                        app:helperText="@string/groq_api_key_helper"
                        app:helperTextEnabled="true"
                        app:endIconMode="password_toggle"
                        app:startIconDrawable="@drawable/ic_key">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_groq_api_key"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textAppearance="@style/TextAppearance.Horizon.BodyMedium" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Save API key button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_save_api_key"
                        style="@style/Widget.Horizon.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="@dimen/space_sm"
                        android:text="@string/btn_save_api_key"
                        android:textAppearance="@style/TextAppearance.Horizon.LabelSmall"
                        app:icon="@drawable/ic_check"
                        app:iconGravity="textStart" />

                    <!-- Language selector for Whisper transcription -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_language"
                        style="@style/Widget.Horizon.TextInputLayout.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:hint="Transcription Language"
                        app:helperText="Select language for better accuracy"
                        app:helperTextEnabled="true"
                        app:startIconDrawable="@drawable/ic_language">

                        <AutoCompleteTextView
                            android:id="@+id/actv_language"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:textAppearance="@style/TextAppearance.Horizon.BodyMedium" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Translation language selector -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_translation_language"
                        style="@style/Widget.Horizon.TextInputLayout.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:hint="Translation Language"
                        app:helperText="Target language for AI translation"
                        app:helperTextEnabled="true"
                        app:startIconDrawable="@drawable/ic_translate">

                        <AutoCompleteTextView
                            android:id="@+id/actv_translation_language"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:textAppearance="@style/TextAppearance.Horizon.BodyMedium" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_generate_subtitles"
                        style="@style/Widget.Horizon.Button.Tonal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/btn_generate_subtitles"
                        app:icon="@drawable/ic_audio_track"
                        app:iconGravity="textStart" />

                    <ProgressBar
                        android:id="@+id/progress_subtitles"
                        style="?android:attr/progressBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="@dimen/space_sm"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_subtitle_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:textAppearance="@style/TextAppearance.Horizon.BodyMedium"
                        android:textColor="@color/colorOnSurface"
                        android:visibility="gone" />

                    <!-- Debug log — shows every step and exact error messages -->
                    <TextView
                        android:id="@+id/tv_debug_log"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:background="@color/colorSurfaceVariant"
                        android:fontFamily="monospace"
                        android:maxLines="30"
                        android:padding="@dimen/space_sm"
                        android:scrollbars="vertical"
                        android:textAppearance="@style/TextAppearance.Horizon.BodySmall"
                        android:textColor="@color/colorOnSurfaceVariant"
                        android:textIsSelectable="true"
                        android:visibility="gone" />

                    <!-- Dialogue list -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_dialogue_list"
                        android:layout_width="match_parent"
                        android:layout_height="240dp"
                        android:layout_marginTop="@dimen/space_md"
                        android:nestedScrollingEnabled="true"
                        android:visibility="gone" />

                    <!-- Select All / Deselect All + Selection count -->
                    <LinearLayout
                        android:id="@+id/layout_dialogue_selection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_select_all_dialogues"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minHeight="32dp"
                            android:paddingHorizontal="8dp"
                            android:text="@string/btn_select_all"
                            android:textAppearance="@style/TextAppearance.Horizon.LabelSmall" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_deselect_all_dialogues"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minHeight="32dp"
                            android:paddingHorizontal="8dp"
                            android:text="@string/btn_deselect_all"
                            android:textAppearance="@style/TextAppearance.Horizon.LabelSmall" />

                        <TextView
                            android:id="@+id/tv_selected_count"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:textAppearance="@style/TextAppearance.Horizon.LabelSmall"
                            android:textColor="@color/colorOnSurfaceVariant"
                            android:text="@string/dialogue_selected_count_default" />
                    </LinearLayout>

                    <!-- Dialogue loop controls -->
                    <LinearLayout
                        android:id="@+id/layout_dialogue_loop_controls"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/dialogue_loop_count_label"
                            android:textAppearance="@style/TextAppearance.Horizon.BodyMedium"
                            android:textColor="@color/colorOnSurface" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_dialogue_loop_minus"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="36dp"
                            android:padding="0dp"
                            android:text="−"
                            android:textAppearance="@style/TextAppearance.Horizon.LabelSmall" />

                        <TextView
                            android:id="@+id/tv_dialogue_loop_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="8dp"
                            android:text="5"
                            android:textAppearance="@style/TextAppearance.Horizon.BodyLarge"
                            android:textColor="@color/colorOnSurface" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_dialogue_loop_plus"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="36dp"
                            android:padding="0dp"
                            android:text="+"
                            android:textAppearance="@style/TextAppearance.Horizon.LabelSmall" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_loop_dialogue"
                            style="@style/Widget.Horizon.Button.Tonal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_sm"
                            android:text="@string/btn_loop_dialogue"
                            android:textAppearance="@style/TextAppearance.Horizon.LabelSmall" />

                    </LinearLayout>

                    <!-- Pause duration controls for natural gap between repetitions -->
                    <LinearLayout
                        android:id="@+id/layout_pause_controls"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/pause_between_label"
                            android:textAppearance="@style/TextAppearance.Horizon.BodyMedium"
                            android:textColor="@color/colorOnSurface" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_pause_minus"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="36dp"
                            android:padding="0dp"
                            android:text="−"
                            android:textAppearance="@style/TextAppearance.Horizon.LabelSmall" />

                        <TextView
                            android:id="@+id/tv_pause_duration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="8dp"
                            android:text="0.8s"
                            android:textAppearance="@style/TextAppearance.Horizon.BodyLarge"
                            android:textColor="@color/colorOnSurface" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_pause_plus"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="36dp"
                            android:padding="0dp"
                            android:text="+"
                            android:textAppearance="@style/TextAppearance.Horizon.LabelSmall" />
                    </LinearLayout>

                    <!-- Dialogue auto-loop button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_start_dialogue_auto_loop"
                        style="@style/Widget.Horizon.Button.Tonal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/btn_start_dialogue_auto_loop"
                        app:icon="@drawable/ic_play"
                        app:iconGravity="textStart"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ════════ Loop Templates ════════ -->
            <TextView
                style="@style/Widget.Horizon.SectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_loop_templates" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Horizon.CardView.Filled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg">

                <LinearLayout
                    android:id="@+id/layout_template_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">

                    <TextView
                        android:id="@+id/tv_template_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/template_no_subtitles"
                        android:textAppearance="@style/TextAppearance.Horizon.BodySmall"
                        android:textColor="@color/colorOnSurfaceVariant" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_create_dialogue_template"
                        style="@style/Widget.Horizon.Button.Tonal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:text="@string/btn_create_template"
                        android:visibility="gone" />

                    <!-- Template list container (dynamically populated) -->
                    <LinearLayout
                        android:id="@+id/layout_template_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="@dimen/space_sm" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ════════ Buttons ════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear"
                    style="@style/Widget.Horizon.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/space_sm"
                    android:text="@string/btn_clear"
                    app:icon="@drawable/ic_close"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_apply"
                    style="@style/Widget.Horizon.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/space_sm"
                    android:text="@string/btn_save"
                    app:icon="@drawable/ic_check"
                    app:iconGravity="textStart" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
