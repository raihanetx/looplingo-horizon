<?xml version="1.0" encoding="utf-8"?>
<!--
    Horizon Loop — Now Playing Screen (v2 Premium Redesign)
    Structure:
      TOP (scrollable):   Hero card → Loop controls → Saved timestamps → Action buttons
      BOTTOM (fixed):     Seek bar → Time → Transport controls
      MIDDLE (scrollable): AI Subtitles → Dialogue list
    The bottom player bar is a direct child of CoordinatorLayout so it stays fixed.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorSurface"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationContentDescription="@string/content_desc_navigate_up"
            app:title="@string/playback_settings"
            app:titleTextAppearance="@style/TextAppearance.Horizon.TitleLarge"
            app:titleTextColor="@color/colorOnSurface" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ═══════════════════════════════════════════════════════════════════════
         SCROLLABLE CONTENT — Hero, Loop, Subtitles, Dialogue, Actions
         ═══════════════════════════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="140dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingTop="@dimen/space_md">

            <!-- ════════════════════════════════════════════════════════════
                 NOW PLAYING HERO — Gradient card with track info
                 ════════════════════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_now_playing"
                style="@style/Widget.Horizon.CardView.Hero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg">

                <!-- Gradient background layer -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_hero_gradient" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingVertical="@dimen/space_xl"
                    android:paddingHorizontal="@dimen/space_lg">

                    <!-- Audio wave icon -->
                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginBottom="@dimen/space_md"
                        android:alpha="0.7"
                        android:contentDescription="@string/content_desc_video_icon"
                        android:scaleType="centerInside"
                        app:srcCompat="@drawable/ic_audio_track"
                        app:tint="@color/colorOnPrimaryContainer" />

                    <!-- Track title -->
                    <TextView
                        android:id="@+id/tv_now_playing_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textAppearance="@style/TextAppearance.Horizon.HeadlineMedium"
                        android:textColor="@color/colorOnPrimaryContainer" />

                    <!-- Speed + AB badge row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- Speed chip — pill-shaped tonal button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_speed_toggle"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="52dp"
                            android:paddingHorizontal="10dp"
                            android:text="1.0x"
                            android:textAppearance="@style/TextAppearance.Horizon.LabelSmall"
                            app:cornerRadius="14dp" />

                        <!-- AB loop indicator badge -->
                        <TextView
                            android:id="@+id/tv_ab_indicator"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_sm"
                            android:background="@drawable/badge_background"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:text="AB"
                            android:textAppearance="@style/TextAppearance.Horizon.LabelSmall"
                            android:textColor="@color/colorOnPrimary"
                            android:visibility="gone" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ════════════════════════════════════════════════════════════
                 LOOP CONTROLS — A-B Range + Loop Count (Glass card)
                 ════════════════════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Horizon.CardView.Glass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <!-- Section header -->
                    <TextView
                        style="@style/Widget.Horizon.SectionHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="0dp"
                        android:text="@string/section_loop_range" />

                    <!-- A/B time inputs row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_range_start"
                            style="@style/Widget.Horizon.TextInputLayout.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/hint_start_time"
                            app:errorEnabled="true">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_range_start"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:text="0:00"
                                android:textAppearance="@style/TextAppearance.Horizon.BodyLarge" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_marginHorizontal="@dimen/space_sm"
                            android:text="@string/range_separator"
                            android:textAppearance="@style/TextAppearance.Horizon.BodyLarge"
                            android:textColor="@color/colorOnSurfaceVariant" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_range_end"
                            style="@style/Widget.Horizon.TextInputLayout.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/hint_end_time"
                            app:errorEnabled="true">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_range_end"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:text=""
                                android:textAppearance="@style/TextAppearance.Horizon.BodyLarge" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:text="@string/hint_time_format"
                        android:textAppearance="@style/TextAppearance.Horizon.BodySmall"
                        android:textColor="@color/colorOnSurfaceVariant" />

                    <!-- Loop count + Try Loop button -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/loop_count_label"
                            android:textAppearance="@style/TextAppearance.Horizon.BodyMedium"
                            android:textColor="@color/colorOnSurface" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_loop_minus"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginStart="@dimen/space_sm"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="32dp"
                            android:padding="0dp"
                            android:text="−"
                            android:textAppearance="@style/TextAppearance.Horizon.LabelSmall"
                            app:cornerRadius="16dp" />

                        <TextView
                            android:id="@+id/tv_loop_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="6dp"
                            android:text="3"
                            android:textAppearance="@style/TextAppearance.Horizon.BodyLarge"
                            android:textColor="@color/colorOnSurface" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_loop_plus"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="32dp"
                            android:padding="0dp"
                            android:text="+"
                            android:textAppearance="@style/TextAppearance.Horizon.LabelSmall"
                            app:cornerRadius="16dp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_try_loop"
                            style="@style/Widget.Horizon.Button.Tonal"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="64dp"
                            android:paddingHorizontal="12dp"
                            android:text="@string/btn_try_loop"
                            android:textAppearance="@style/TextAppearance.Horizon.LabelSmall"
                            app:cornerRadius="18dp"
                            app:icon="@drawable/ic_play"
                            app:iconGravity="textStart" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ════════════════════════════════════════════════════════════
                 SAVED TIMESTAMPS (conditionally visible)
                 ════════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/layout_saved_timestamps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/Widget.Horizon.SectionHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/section_saved_timestamps" />

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Horizon.CardView.Glass"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_md">

                    <LinearLayout
                        android:id="@+id/saved_timestamps_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_md" />

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ════════════════════════════════════════════════════════════
                 AI SUBTITLES + DIALOGUE LIST (Glass card)
                 ════════════════════════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Horizon.CardView.Glass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <!-- Section header -->
                    <TextView
                        style="@style/Widget.Horizon.SectionHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="0dp"
                        android:text="@string/section_ai_subtitles" />

                    <!-- API Key banner — warning when no key is set -->
                    <TextView
                        android:id="@+id/tv_api_key_banner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_md"
                        android:background="@color/colorErrorContainer"
                        android:paddingHorizontal="@dimen/space_md"
                        android:paddingVertical="@dimen/space_sm"
                        android:text="@string/api_key_required_banner"
                        android:textAppearance="@style/TextAppearance.Horizon.BodyMedium"
                        android:textColor="@color/colorOnErrorContainer"
                        android:visibility="gone" />

                    <!-- Groq API Key input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_groq_api_key"
                        style="@style/Widget.Horizon.TextInputLayout.Filled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_groq_api_key"
                        app:helperText="@string/groq_api_key_helper"
                        app:helperTextEnabled="true"
                        app:endIconMode="password_toggle"
                        app:startIconDrawable="@drawable/ic_key">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_groq_api_key"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textAppearance="@style/TextAppearance.Horizon.BodyMedium" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Save API key button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_save_api_key"
                        style="@style/Widget.Horizon.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="@dimen/space_sm"
                        android:text="@string/btn_save_api_key"
                        android:textAppearance="@style/TextAppearance.Horizon.LabelSmall"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_check"
                        app:iconGravity="textStart" />

                    <!-- Language selectors row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:orientation="horizontal">

                        <!-- Transcription language -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_language"
                            style="@style/Widget.Horizon.TextInputLayout.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/space_xs"
                            android:hint="Language"
                            app:startIconDrawable="@drawable/ic_language">

                            <AutoCompleteTextView
                                android:id="@+id/actv_language"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"
                                android:textAppearance="@style/TextAppearance.Horizon.BodyMedium" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Translation language -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_translation_language"
                            style="@style/Widget.Horizon.TextInputLayout.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/space_xs"
                            android:hint="Translate"
                            app:startIconDrawable="@drawable/ic_translate">

                            <AutoCompleteTextView
                                android:id="@+id/actv_translation_language"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"
                                android:textAppearance="@style/TextAppearance.Horizon.BodyMedium" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <!-- Generate button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_generate_subtitles"
                        style="@style/Widget.Horizon.Button.Tonal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/btn_generate_subtitles"
                        app:cornerRadius="20dp"
                        app:icon="@drawable/ic_audio_track"
                        app:iconGravity="textStart" />

                    <!-- Progress -->
                    <ProgressBar
                        android:id="@+id/progress_subtitles"
                        style="?android:attr/progressBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="@dimen/space_sm"
                        android:visibility="gone" />

                    <!-- Status text -->
                    <TextView
                        android:id="@+id/tv_subtitle_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:textAppearance="@style/TextAppearance.Horizon.BodyMedium"
                        android:textColor="@color/colorOnSurface"
                        android:visibility="gone" />

                    <!-- Debug log (debug builds only) -->
                    <TextView
                        android:id="@+id/tv_debug_log"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:background="@color/colorSurfaceVariant"
                        android:fontFamily="monospace"
                        android:maxLines="20"
                        android:padding="@dimen/space_sm"
                        android:scrollbars="vertical"
                        android:textAppearance="@style/TextAppearance.Horizon.BodySmall"
                        android:textColor="@color/colorOnSurfaceVariant"
                        android:textIsSelectable="true"
                        android:visibility="gone" />

                    <!-- Dialogue list -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_dialogue_list"
                        android:layout_width="match_parent"
                        android:layout_height="240dp"
                        android:layout_marginTop="@dimen/space_md"
                        android:nestedScrollingEnabled="true"
                        android:visibility="gone" />

                    <!-- Dialogue loop controls -->
                    <LinearLayout
                        android:id="@+id/layout_dialogue_loop_controls"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/dialogue_loop_count_label"
                            android:textAppearance="@style/TextAppearance.Horizon.BodyMedium"
                            android:textColor="@color/colorOnSurface" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_dialogue_loop_minus"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="36dp"
                            android:padding="0dp"
                            android:text="−"
                            android:textAppearance="@style/TextAppearance.Horizon.LabelSmall"
                            app:cornerRadius="18dp" />

                        <TextView
                            android:id="@+id/tv_dialogue_loop_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="8dp"
                            android:text="3"
                            android:textAppearance="@style/TextAppearance.Horizon.BodyLarge"
                            android:textColor="@color/colorOnSurface" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_dialogue_loop_plus"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="36dp"
                            android:padding="0dp"
                            android:text="+"
                            android:textAppearance="@style/TextAppearance.Horizon.LabelSmall"
                            app:cornerRadius="18dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_loop_dialogue"
                            style="@style/Widget.Horizon.Button.Tonal"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_marginStart="@dimen/space_sm"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="64dp"
                            android:paddingHorizontal="12dp"
                            android:text="@string/btn_loop_dialogue"
                            android:textAppearance="@style/TextAppearance.Horizon.LabelSmall"
                            app:cornerRadius="18dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ════════════════════════════════════════════════════════════
                 BOTTOM ACTION BUTTONS
                 ════════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/space_lg">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear"
                    style="@style/Widget.Horizon.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/space_sm"
                    android:text="@string/btn_clear"
                    app:cornerRadius="20dp"
                    app:icon="@drawable/ic_close"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_apply"
                    style="@style/Widget.Horizon.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/space_sm"
                    android:text="@string/btn_save"
                    app:cornerRadius="20dp"
                    app:icon="@drawable/ic_check"
                    app:iconGravity="textStart" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ═══════════════════════════════════════════════════════════════════════
         FIXED BOTTOM PLAYER BAR — Always visible, never scrolls away
         Premium Spotify/YouTube Music inspired controls
         ═══════════════════════════════════════════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_bottom_player"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardCornerRadius="0dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/colorPlayerBar"
        app:strokeColor="@color/colorOutlineVariant"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingTop="@dimen/space_sm">

            <!-- Seek bar row -->
            <SeekBar
                android:id="@+id/seek_bar_player"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="1000"
                android:progress="0"
                android:contentDescription="@string/content_desc_seek_bar"
                android:splitTrack="false"
                android:progressTint="@color/colorPrimary"
                android:progressBackgroundTint="@color/colorSurfaceVariant"
                android:thumbTint="@color/colorPrimary" />

            <!-- Time row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp">

                <TextView
                    android:id="@+id/tv_current_position"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Horizon.LabelSmall"
                    android:textColor="@color/colorOnSurfaceVariant" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tv_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Horizon.LabelSmall"
                    android:textColor="@color/colorOnSurfaceVariant" />

            </LinearLayout>

            <!-- Transport controls: ⏮ ⏪ ▶️/⏸ ⏩ ⏭ with Stop
                 Centered row with FAB-style play button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/space_sm">

                <!-- Skip Previous — transport circle -->
                <ImageView
                    android:id="@+id/iv_skip_previous"
                    android:layout_width="@dimen/transport_button_size"
                    android:layout_height="@dimen/transport_button_size"
                    android:background="@drawable/bg_transport_button"
                    android:contentDescription="@string/notification_previous"
                    android:padding="@dimen/space_md"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/ic_skip_previous"
                    app:tint="@color/colorOnSurface" />

                <!-- Rewind 5s — transport circle -->
                <ImageView
                    android:id="@+id/iv_rewind_5"
                    android:layout_width="@dimen/transport_button_size"
                    android:layout_height="@dimen/transport_button_size"
                    android:layout_marginStart="@dimen/space_sm"
                    android:background="@drawable/bg_transport_button"
                    android:contentDescription="@string/content_desc_rewind_5"
                    android:padding="@dimen/space_md"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/ic_rewind_5"
                    app:tint="@color/colorOnSurface" />

                <!-- Play/Pause — large FAB-style circle -->
                <ImageView
                    android:id="@+id/iv_play_pause"
                    android:layout_width="@dimen/play_button_size"
                    android:layout_height="@dimen/play_button_size"
                    android:layout_marginHorizontal="@dimen/space_sm"
                    android:background="@drawable/bg_play_button"
                    android:contentDescription="@string/content_desc_play_pause"
                    android:padding="@dimen/space_lg"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/ic_play"
                    app:tint="@color/colorOnPrimary" />

                <!-- Forward 5s — transport circle -->
                <ImageView
                    android:id="@+id/iv_forward_5"
                    android:layout_width="@dimen/transport_button_size"
                    android:layout_height="@dimen/transport_button_size"
                    android:background="@drawable/bg_transport_button"
                    android:contentDescription="@string/content_desc_forward_5"
                    android:padding="@dimen/space_md"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/ic_forward_5"
                    app:tint="@color/colorOnSurface" />

                <!-- Skip Next — transport circle -->
                <ImageView
                    android:id="@+id/iv_skip_next"
                    android:layout_width="@dimen/transport_button_size"
                    android:layout_height="@dimen/transport_button_size"
                    android:layout_marginStart="@dimen/space_sm"
                    android:background="@drawable/bg_transport_button"
                    android:contentDescription="@string/notification_next"
                    android:padding="@dimen/space_md"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/ic_skip_next"
                    app:tint="@color/colorOnSurface" />

                <!-- Stop — smaller, subdued -->
                <ImageView
                    android:id="@+id/iv_stop"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="@dimen/space_lg"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/content_desc_stop"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/ic_stop"
                    app:tint="@color/colorOnSurfaceVariant" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
