<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/space_lg"
    android:layout_marginVertical="@dimen/space_xs"
    app:cardCornerRadius="@dimen/glass_card_corner_radius"
    app:cardElevation="@dimen/card_elevation"
    app:strokeColor="@color/colorOutlineVariant"
    app:strokeWidth="0dp"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/video_item_height"
        android:paddingHorizontal="@dimen/space_lg"
        android:paddingVertical="@dimen/space_md">

        <!-- Audio track icon — larger icon container (52dp) with rounded corners -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_icon_bg"
            android:layout_width="52dp"
            android:layout_height="52dp"
            app:cardCornerRadius="@dimen/glass_card_corner_radius"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/colorPrimaryContainer"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/iv_video_icon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:contentDescription="@string/content_desc_video_icon"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/ic_audio_track"
                app:tint="@color/colorOnPrimaryContainer" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Loop mode badge (top-right corner of icon) -->
        <TextView
            android:id="@+id/tv_loop_badge"
            android:layout_width="@dimen/video_item_badge_size"
            android:layout_height="@dimen/video_item_badge_size"
            android:background="@drawable/badge_background"
            android:gravity="center"
            android:textColor="@color/colorOnPrimary"
            android:textSize="10sp"
            android:visibility="gone"
            android:contentDescription="@string/content_desc_loop_badge"
            app:layout_constraintEnd_toEndOf="@id/card_icon_bg"
            app:layout_constraintTop_toTopOf="@id/card_icon_bg"
            tools:text="∞"
            tools:visibility="visible" />

        <!-- Video title -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_md"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.Horizon.TitleMedium"
            android:textColor="@color/colorOnSurface"
            app:layout_constraintEnd_toStartOf="@id/tv_duration"
            app:layout_constraintStart_toEndOf="@id/card_icon_bg"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Chapter 03 - Introducing Yourself" />

        <!-- Video path (secondary info) -->
        <TextView
            android:id="@+id/tv_path"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_md"
            android:layout_marginTop="@dimen/space_xs"
            android:ellipsize="middle"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.Horizon.BodySmall"
            android:textColor="@color/colorOnSurfaceVariant"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/card_icon_bg"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            tools:text="/storage/emulated/0/Movies/lesson3.mp4" />

        <!-- Duration (right-aligned) -->
        <TextView
            android:id="@+id/tv_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Horizon.LabelMedium"
            android:textColor="@color/colorOnSurfaceVariant"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="05:32" />

        <!-- File size (below path, with better spacing) -->
        <TextView
            android:id="@+id/tv_size"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_md"
            android:layout_marginTop="@dimen/space_xs"
            android:textAppearance="@style/TextAppearance.Horizon.LabelSmall"
            android:textColor="@color/colorOutline"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/card_icon_bg"
            app:layout_constraintTop_toBottomOf="@id/tv_path"
            tools:text="24.5 MB" />

        <!-- Subtitle status chip with icon -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_subtitle_status"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:layout_marginStart="@dimen/space_md"
            android:layout_marginTop="@dimen/space_xs"
            android:visibility="gone"
            app:chipIcon="@drawable/ic_audio_track"
            app:chipIconVisible="true"
            app:chipIconSize="12dp"
            app:chipMinHeight="24dp"
            app:chipStartPadding="4dp"
            app:chipEndPadding="4dp"
            app:chipBackgroundColor="@color/colorTertiaryContainer"
            app:textStartPadding="4dp"
            app:textEndPadding="4dp"
            android:textAppearance="@style/TextAppearance.Horizon.LabelSmall"
            android:textColor="@color/colorOnTertiaryContainer"
            app:layout_constraintStart_toEndOf="@id/card_icon_bg"
            app:layout_constraintTop_toBottomOf="@id/tv_size"
            tools:text="Subtitles"
            tools:visibility="visible" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
