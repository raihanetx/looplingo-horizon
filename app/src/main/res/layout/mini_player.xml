<?xml version="1.0" encoding="utf-8"?>
<!-- Mini Player — compact bottom bar (Spotify/YouTube Music style)
     Shows at the top of the main screen when audio is playing.
     Tap to expand to full player (navigate to PlaybackSettings). -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mini_player_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/space_sm"
    android:layout_marginVertical="@dimen/space_xs"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/colorSurfaceContainerLow"
    app:strokeColor="@color/colorOutlineVariant"
    app:strokeWidth="0dp"
    app:rippleColor="@color/colorPrimary"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Thin progress line at top -->
        <ProgressBar
            android:id="@+id/progress_mini_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:max="1000"
            android:progress="0"
            android:progressTint="@color/colorPrimary"
            android:progressBackgroundTint="@color/colorSurfaceVariant"
            android:indeterminate="false" />

        <!-- Content row: icon + title + time + play/pause + close -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/space_md"
            android:paddingVertical="@dimen/space_sm">

            <!-- Audio track icon -->
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="@string/content_desc_video_icon"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/ic_audio_track"
                app:tint="@color/colorPrimary" />

            <!-- Title + time -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/space_sm"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_mini_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textAppearance="@style/TextAppearance.Horizon.BodyMedium"
                    android:textColor="@color/colorOnSurface" />

                <TextView
                    android:id="@+id/tv_mini_position"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Horizon.LabelSmall"
                    android:textColor="@color/colorOnSurfaceVariant" />

            </LinearLayout>

            <!-- AB indicator badge (shown when AB loop is active) -->
            <TextView
                android:id="@+id/tv_mini_ab_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_sm"
                android:background="@drawable/badge_background"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:text="AB"
                android:textAppearance="@style/TextAppearance.Horizon.LabelSmall"
                android:textColor="@color/colorOnPrimary"
                android:visibility="gone" />

            <!-- Play/Pause -->
            <ImageView
                android:id="@+id/iv_mini_play_pause"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/content_desc_play_pause"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/ic_pause"
                app:tint="@color/colorOnSurface" />

            <!-- Close/Stop -->
            <ImageView
                android:id="@+id/iv_mini_close"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="@dimen/space_xs"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/content_desc_stop_playback"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/ic_close"
                app:tint="@color/colorOnSurfaceVariant" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
