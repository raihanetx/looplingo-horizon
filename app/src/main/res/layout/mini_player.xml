<?xml version="1.0" encoding="utf-8"?>
<!-- Mini Player — Premium bottom bar (Spotify/YouTube Music style)
     Fixed at the bottom of the main screen when audio is playing.
     Tap to expand to full player (navigate to PlaybackSettings). -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mini_player_card"
    android:layout_width="match_parent"
    android:layout_height="@dimen/mini_player_height"
    android:layout_marginHorizontal="0dp"
    android:layout_marginVertical="0dp"
    app:cardCornerRadius="0dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/colorPlayerBar"
    app:strokeColor="@color/colorOutlineVariant"
    app:strokeWidth="0dp"
    app:rippleColor="@color/colorPrimary"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Thicker progress line at top (3dp) -->
        <ProgressBar
            android:id="@+id/progress_mini_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:max="1000"
            android:progress="0"
            android:progressTint="@color/colorPrimary"
            android:progressBackgroundTint="@color/colorSurfaceVariant"
            android:indeterminate="false" />

        <!-- Content row: icon + title + time + play/pause + close -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingVertical="@dimen/space_xs">

            <!-- Audio track icon — slightly larger for premium feel -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="@dimen/glass_card_corner_radius"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/colorPrimaryContainer">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/content_desc_video_icon"
                    android:scaleType="centerInside"
                    app:srcCompat="@drawable/ic_audio_track"
                    app:tint="@color/colorOnPrimaryContainer" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Title + time -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/space_md"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_mini_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textAppearance="@style/TextAppearance.Horizon.BodyMedium"
                    android:textColor="@color/colorOnSurface" />

                <TextView
                    android:id="@+id/tv_mini_position"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Horizon.LabelSmall"
                    android:textColor="@color/colorOnSurfaceVariant" />

            </LinearLayout>

            <!-- AB indicator badge (shown when AB loop is active) -->
            <TextView
                android:id="@+id/tv_mini_ab_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_sm"
                android:background="@drawable/badge_background"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:text="AB"
                android:textAppearance="@style/TextAppearance.Horizon.LabelSmall"
                android:textColor="@color/colorOnPrimary"
                android:visibility="gone" />

            <!-- Play/Pause — 44dp touch target -->
            <ImageView
                android:id="@+id/iv_mini_play_pause"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/content_desc_play_pause"
                android:padding="@dimen/space_sm"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/ic_pause"
                app:tint="@color/colorOnSurface" />

            <!-- Close/Stop -->
            <ImageView
                android:id="@+id/iv_mini_close"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="@dimen/space_xs"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/content_desc_stop_playback"
                android:padding="@dimen/space_xs"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/ic_close"
                app:tint="@color/colorOnSurfaceVariant" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
