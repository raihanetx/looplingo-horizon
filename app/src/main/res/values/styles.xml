<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ══════════════════════════════════════════════════════════════════════
         TEXT APPEARANCE — Material 3 Type Scale
         ══════════════════════════════════════════════════════════════════════ -->

    <style name="TextAppearance.Horizon.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">@dimen/text_display_large</item>
    </style>

    <style name="TextAppearance.Horizon.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/text_headline_medium</item>
    </style>

    <style name="TextAppearance.Horizon.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/text_title_large</item>
    </style>

    <style name="TextAppearance.Horizon.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/text_title_medium</item>
    </style>

    <style name="TextAppearance.Horizon.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/text_title_small</item>
    </style>

    <style name="TextAppearance.Horizon.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">@dimen/text_body_large</item>
    </style>

    <style name="TextAppearance.Horizon.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">@dimen/text_body_medium</item>
    </style>

    <style name="TextAppearance.Horizon.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">@dimen/text_body_small</item>
    </style>

    <style name="TextAppearance.Horizon.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/text_label_large</item>
    </style>

    <style name="TextAppearance.Horizon.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/text_label_medium</item>
    </style>

    <style name="TextAppearance.Horizon.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/text_label_small</item>
    </style>

    <!-- ══════════════════════════════════════════════════════════════════════
         CARD STYLES
         ══════════════════════════════════════════════════════════════════════ -->

    <style name="Widget.Horizon.CardView.Filled" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardBackgroundColor">@color/colorSurfaceContainerLow</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="Widget.Horizon.CardView.Elevated" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardBackgroundColor">@color/colorSurfaceContainerLow</item>
        <item name="cardElevation">@dimen/card_elevation</item>
    </style>

    <style name="Widget.Horizon.CardView.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="strokeColor">@color/colorOutlineVariant</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Hero card — large radius, gradient background, premium feel -->
    <style name="Widget.Horizon.CardView.Hero" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/hero_card_corner_radius</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/colorPrimaryContainer</item>
    </style>

    <!-- Glass card — frosted glass effect, medium radius -->
    <style name="Widget.Horizon.CardView.Glass" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">@dimen/glass_card_corner_radius</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/colorSurfaceContainer</item>
    </style>

    <!-- ══════════════════════════════════════════════════════════════════════
         BUTTON STYLES
         ══════════════════════════════════════════════════════════════════════ -->

    <style name="Widget.Horizon.Button" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:textAppearance">@style/TextAppearance.Horizon.LabelLarge</item>
    </style>

    <style name="Widget.Horizon.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:textAppearance">@style/TextAppearance.Horizon.LabelLarge</item>
    </style>

    <style name="Widget.Horizon.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:textAppearance">@style/TextAppearance.Horizon.LabelLarge</item>
    </style>

    <style name="Widget.Horizon.Button.Icon" parent="Widget.Material3.Button.IconButton">
        <item name="android:minWidth">@dimen/touch_target_min</item>
        <item name="android:minHeight">@dimen/touch_target_min</item>
    </style>

    <!-- Transport button — circular, tonal, for playback controls -->
    <style name="Widget.Horizon.Button.Transport" parent="Widget.Material3.Button.IconButton">
        <item name="android:minWidth">@dimen/transport_button_size</item>
        <item name="android:minHeight">@dimen/transport_button_size</item>
        <item name="android:width">@dimen/transport_button_size</item>
        <item name="android:height">@dimen/transport_button_size</item>
        <item name="android:background">@drawable/bg_transport_button</item>
        <item name="iconTint">@color/colorOnSurface</item>
        <item name="iconSize">24dp</item>
    </style>

    <!-- ══════════════════════════════════════════════════════════════════════
         INPUT STYLES
         ══════════════════════════════════════════════════════════════════════ -->

    <style name="Widget.Horizon.TextInputLayout.Filled" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxCornerRadiusTopStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/input_corner_radius</item>
        <item name="materialThemeOverlay">@style/ThemeOverlay.Horizon.TextInputLayout</item>
    </style>

    <style name="Widget.Horizon.TextInputLayout.Outlined" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/input_corner_radius</item>
        <item name="materialThemeOverlay">@style/ThemeOverlay.Horizon.TextInputLayout</item>
    </style>

    <style name="ThemeOverlay.Horizon.TextInputLayout" parent="">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <item name="colorError">@color/colorError</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.Horizon.BodySmall</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.Horizon.TitleMedium</item>
    </style>

    <!-- ══════════════════════════════════════════════════════════════════════
         EXPOSED DROPDOWN (replaces Spinner)
         ══════════════════════════════════════════════════════════════════════ -->

    <style name="Widget.Horizon.ExposedDropdown" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxCornerRadiusTopStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/input_corner_radius</item>
    </style>

    <!-- ══════════════════════════════════════════════════════════════════════
         SWITCH (replaces CheckBox for auto-advance)
         ══════════════════════════════════════════════════════════════════════ -->

    <style name="Widget.Horizon.Switch" parent="">
        <item name="materialThemeOverlay">@style/ThemeOverlay.Horizon.Switch</item>
    </style>

    <style name="ThemeOverlay.Horizon.Switch" parent="">
        <item name="colorPrimary">@color/colorTertiary</item>
        <item name="colorOnPrimary">@color/colorOnTertiary</item>
        <item name="colorSurface">@color/colorSurfaceVariant</item>
    </style>

    <!-- ══════════════════════════════════════════════════════════════════════
         SECTION HEADER (for settings screen grouping)
         ══════════════════════════════════════════════════════════════════════ -->

    <style name="Widget.Horizon.SectionHeader" parent="android:Widget.TextView">
        <item name="android:textAppearance">@style/TextAppearance.Horizon.LabelLarge</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:paddingTop">@dimen/space_lg</item>
        <item name="android:paddingBottom">@dimen/space_sm</item>
    </style>

    <!-- ══════════════════════════════════════════════════════════════════════
         SLIDER — Player seek slider
         ══════════════════════════════════════════════════════════════════════ -->

    <style name="Widget.Horizon.Slider" parent="Widget.Material3.Slider">
        <item name="thumbColor">@color/colorPrimary</item>
        <item name="trackColorActive">@color/colorPrimary</item>
        <item name="trackColorInactive">@color/colorSurfaceVariant</item>
        <item name="haloColor">@color/colorPrimaryContainer</item>
        <item name="haloRadius">16dp</item>
        <item name="thumbElevation">2dp</item>
    </style>

    <!-- ══════════════════════════════════════════════════════════════════════
         CHIP — Selectable dialogue line
         ══════════════════════════════════════════════════════════════════════ -->

    <style name="Widget.Horizon.Chip.Selectable" parent="Widget.Material3.Chip.Input">
        <item name="chipBackgroundColor">@color/colorSurfaceContainer</item>
        <item name="chipStrokeColor">@color/colorOutlineVariant</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipCornerRadius">@dimen/dialogue_item_corner_radius</item>
        <item name="android:textAppearance">@style/TextAppearance.Horizon.BodyMedium</item>
        <item name="android:textColor">@color/colorOnSurface</item>
    </style>

    <!-- ══════════════════════════════════════════════════════════════════════
         SNACKBAR
         ══════════════════════════════════════════════════════════════════════ -->

    <style name="Widget.Horizon.Snackbar" parent="Widget.Material3.Snackbar">
        <item name="actionTextColorAlpha">1.0</item>
        <item name="android:backgroundTint">@color/colorInverseSurface</item>
    </style>

    <style name="Widget.Horizon.Snackbar.TextView" parent="Widget.Material3.Snackbar.TextView">
        <item name="android:textAppearance">@style/TextAppearance.Horizon.BodyMedium</item>
        <item name="android:textColor">@color/colorInverseOnSurface</item>
    </style>
</resources>
